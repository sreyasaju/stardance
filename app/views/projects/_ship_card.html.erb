<%# Cream-tinted ship-event card. Reused for every ShipEvent post on the
    project page, home feed, and profile feed. Pass `ship_number: n` for a
    sequential label (e.g. "Ship #2"); omit for a generic "Ship" label. %>
<%
  ship        = post.postable
  author      = post.user
  ship_text   = ship.body.to_s
  total_hours = (project.duration_seconds / 3600.0).round
  ship_number      = local_assigns[:ship_number]
  recert_modal_id  = local_assigns[:recert_modal_id]
  pending_review   = ship.certification_status == "pending"
  track_engagement = local_assigns.fetch(:track_engagement, true)
  demo_url         = local_assigns.fetch(:demo_url, project.demo_url)
  repo_url         = local_assigns.fetch(:repo_url, project.repo_url)
  payout_review    = local_assigns[:payout_review]
  engagement_data = if track_engagement
    {
      controller: "feed-engagement",
      feed_engagement_item_type_value: "post",
      feed_engagement_post_id_value: post.id,
      feed_engagement_project_id_value: project.id,
      feed_engagement_post_type_value: post.postable_type,
      feed_engagement_source_value: local_assigns[:source],
      feed_engagement_position_value: local_assigns[:position],
      feed_engagement_page_value: local_assigns[:page],
      feed_engagement_feed_request_id_value: local_assigns[:feed_request_id]
    }.compact
  else
    {}
  end
%>

<article class="feed-post-card project-show__latest-ship" <%= tag.attributes(data: engagement_data) %>>
  <div class="feed-post-card__reposted-by project-show__latest-ship-label">
    <%= inline_svg_tag "icons/sticker.svg", class: "project-show__latest-ship-icon" %>
    <span><%= ship_number ? "Ship ##{ship_number}" : "Ship" %></span>
    <% if pending_review %>
      <span class="project-show__latest-ship-status project-show__latest-ship-status--pending">Pending review</span>
    <% elsif ship.certification_status == "returned" %>
      <% if recert_modal_id %>
        <button type="button"
                class="project-show__latest-ship-status project-show__latest-ship-status--returned project-show__latest-ship-status--clickable"
                onclick="document.getElementById(<%= recert_modal_id.to_json %>).showModal()"
                aria-haspopup="dialog">
          Changes requested ↗
        </button>
      <% else %>
        <span class="project-show__latest-ship-status project-show__latest-ship-status--returned">Changes requested</span>
      <% end %>
    <% end %>
    <% mission_sub = ship.mission_submission %>
    <% if local_assigns[:is_member] || current_user&.admin? %>
      <% if mission_sub&.pending? || mission_sub&.awaiting_certification? %>
        <span class="project-show__latest-ship-status project-show__latest-ship-status--pending">Pending mission review</span>
      <% elsif mission_sub&.rejected? %>
        <% mission_modal_id = local_assigns[:mission_resubmit_modal_id] %>
        <% if mission_modal_id %>
          <button type="button"
                  class="project-show__latest-ship-status project-show__latest-ship-status--returned project-show__latest-ship-status--clickable"
                  onclick="document.getElementById(<%= mission_modal_id.to_json %>).showModal()"
                  aria-haspopup="dialog">
            Mission returned ↗
          </button>
        <% else %>
          <span class="project-show__latest-ship-status project-show__latest-ship-status--returned">Mission returned</span>
        <% end %>
      <% elsif mission_sub&.approved? && mission_sub.shop_order_id.nil? && mission_sub.mission.prizes_count > 0 %>
        <%= link_to redeem_mission_submission_path(mission_sub),
                    class: "project-show__latest-ship-status project-show__latest-ship-status--approved project-show__latest-ship-status--clickable" do %>
          Claim prize ↗
        <% end %>
      <% end %>
    <% end %>
  </div>

  <header class="feed-post-card__header">
    <% if author %>
      <%= link_to profile_path(author.display_name), class: "feed-post-card__avatar-link", aria: { label: "@#{author.display_name}" } do %>
        <%= image_tag author.avatar, alt: "", class: "feed-post-card__avatar" %>
      <% end %>
    <% end %>

    <div class="feed-post-card__meta">
      <p class="feed-post-card__byline">
        <% if author %>
          <%= link_to "@#{author.display_name}",
                      profile_path(author.display_name),
                      class: "feed-post-card__author",
                      data: { turbo_frame: "_top", turbo_prefetch: "true" } %><%= render StreakBadgeComponent.new(user: author) %>
        <% end %>
        <span class="feed-post-card__context">on</span>
        <%= link_to project.title, project_path(project), class: "feed-post-card__project", data: { turbo_frame: "_top" } %>
        <time class="feed-post-card__time" datetime="<%= post.created_at.iso8601 %>" title="<%= l(post.created_at, format: :long) %>">
          · <%= time_ago_in_words(post.created_at) %> ago
        </time>
      </p>

      <% if ship_text.present? %>
        <div class="feed-post-card__body feed-post-card__body--inline project-show__latest-ship-text">
          <%= simple_format(ship_text, {}, sanitize: true) %>
        </div>
      <% end %>
    </div>
  </header>

  <%= render "shared/post_media", attachments: ship.attachments %>

  <ul class="feed-post-card__body project-show__latest-ship-stats" aria-label="Project totals">
    <li class="profile-project-card__meta-item">
      <%= inline_svg_tag "icons/devlogs.svg", class: "profile-project-card__meta-icon" %>
      <span><%= pluralize(project.devlogs_count, "devlog") %></span>
    </li>
    <li class="profile-project-card__meta-item profile-project-card__meta-item--time">
      <%= inline_svg_tag "icons/time.svg", class: "profile-project-card__meta-icon profile-project-card__meta-icon--time" %>
      <span><%= total_hours %>h</span>
    </li>
    <% mission = ship.mission_submission&.mission %>
    <% if mission %>
      <li class="profile-project-card__meta-item profile-project-card__meta-item--mission">
        <%= inline_svg_tag "icons/flag.svg", class: "profile-project-card__meta-icon profile-project-card__meta-icon--mission" %>
        <span>
          <%= link_to mission.name,
                      mission_path(mission.slug),
                      class: "project-show__latest-ship-mission-link",
                      data: { turbo_frame: "_top" } %>
        </span>
      </li>
    <% end %>
  </ul>

  <% if demo_url.present? || repo_url.present? || payout_review.present? %>
    <div class="feed-post-card__body project-show__latest-ship-cta">
      <% if demo_url.present? %>
        <%= link_to project.hardware? ? "Video of Project →" : "Try project →",
                    demo_url,
                    target: "_blank",
                    rel: "noopener",
                    class: "project-show__latest-ship-btn project-show__latest-ship-btn--primary" %>
      <% end %>
      <% if repo_url.present? %>
        <%= link_to "See source code →",
                    repo_url,
                    target: "_blank",
                    rel: "noopener",
                    class: "project-show__latest-ship-btn" %>
      <% end %>
      <% if payout_review.present? %>
        <button type="button"
                class="project-show__latest-ship-btn"
                onclick="document.getElementById('payout-review-modal').showModal()"
                aria-haspopup="dialog">
          Review payout →
        </button>
      <% end %>
    </div>
  <% end %>
</article>
