<section class="cta-section">
  <% new_onboarding = local_assigns.fetch(:new_onboarding) { Flipper.enabled?(:new_onboarding) } %>
  <h2 class="cta-section__title">Make this summer <span class="cta-section__title--italic">count.</span></h2>

  <p class="cta-section__subtitle">What else are you gonna do?<br>Sign up and build something you&rsquo;re actually proud of.<% unless new_onboarding %><br><br>Stardance Challenge launches on <strong>June 1</strong>.<% end %></p>

  <div class="cta-section__form">
    <%= render "landing/sections/rsvp_form",
          new_onboarding: new_onboarding,
          trailing: image_tag("landing/cta/star-creature.png", class: "rsvp-form__star", alt: "") do %>
      <p class="cta-section__caption">For all teens aged 13&ndash;18.</p>
    <% end %>
  </div>
</section>
