header ":mag: New mission submission to review"

section "*<#{mission_url}|#{mission_name}>* has a new submission ready for review.", markdown: true

section "Project: *<#{project_url}|#{project_title}>* by #{builder_name}\nPath: *#{payout_path}*", markdown: true

actions [
  button("Review submission", "review_submission", url: submission_url)
]

context [
  mrkdwn_text("You're getting this because you're a reviewer on this mission. Toggle off in profile settings.")
]
