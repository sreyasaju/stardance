<%# Renders a ledger entry log table.
    Usage:
      render "admin/shared/ledger_log", entries: @user.ledger_entries
      render "admin/shared/ledger_log", entries: LedgerEntry.where(...), title: "Project Ledger"
    Optional: limit (default 15), title (default "Ledger History") %>
<% entries = local_assigns[:entries] || LedgerEntry.none %>
<% limit = local_assigns.fetch(:limit, 15) %>
<% title = local_assigns.fetch(:title, "Ledger History") %>
<% entries = entries.order(created_at: :desc) %>
<% displayed_entries = entries.limit(limit).includes(:user) %>

<div class="mission-panel">
  <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom: var(--space-s);">
    <h2 class="admin-user-show__section-title" style="margin:0;"><%= stardust_icon %> <%= title %></h2>
    <span class="admin-user-show__muted"><%= entries.count %> entries</span>
  </div>

  <% if displayed_entries.any? %>
    <div>
    <table class="space-table">
      <thead>
        <tr>
          <th>Timestamp</th>
          <th>User</th>
          <th>Amount</th>
          <th>Reason</th>
          <th>Source</th>
        </tr>
      </thead>
      <tbody>
        <% displayed_entries.each do |entry| %>
          <tr>
            <td>
              <span><%= entry.created_at.strftime("%b %d, %Y") %></span>
              <span><%= entry.created_at.strftime("%H:%M:%S") %></span>
            </td>
            <td>
              <% if entry.user %>
                <div>
                  <img src="<%= entry.user.avatar %>" alt="" class="space-table__avatar">
                  <span><%= entry.user.display_name %></span>
                </div>
              <% else %>
                <span>—</span>
              <% end %>
            </td>
            <td>
              <span>
                <%= entry.amount.positive? ? "+#{entry.amount}" : entry.amount %> <%= stardust_icon %>
              </span>
            </td>
            <td><%= truncate(entry.reason.to_s, length: 60) %></td>
            <td>
              <code><%= entry.ledgerable_type.underscore.humanize %> #<%= entry.ledgerable_id %></code>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    </div>
  <% else %>
    <p class="admin-user-show__muted">No ledger entries yet.</p>
  <% end %>
</div>
