<div class="shop-orders__stats">
  <h2 class="shop-orders__stats-title">Statistics</h2>
  <p class="shop-orders__stats-hint">Click a status to filter orders:</p>
  <div class="shop-orders__stat-grid">
    <%= link_to admin_shop_orders_path(preserved_filter_params.merge(status: 'pending')),
        class: "shop-orders__stat badge badge-pending" do %>
      Pending <span class="shop-orders__stat-count"><%= counts[:pending] %></span>
    <% end %>

    <% if policy(:admin).view_fraud_review_filters? %>
      <%= link_to admin_shop_orders_path(preserved_filter_params.merge(status: 'awaiting_verification')),
          class: "shop-orders__stat badge badge-awaiting_verification" do %>
        Awaiting Verification <span class="shop-orders__stat-count"><%= counts[:awaiting_verification] %></span>
      <% end %>
    <% end %>

    <%= link_to admin_shop_orders_path(preserved_filter_params.merge(status: 'awaiting_verification_call')),
        class: "shop-orders__stat badge badge-awaiting_verification" do %>
      Verification Call <span class="shop-orders__stat-count"><%= counts[:awaiting_verification_call] %></span>
    <% end %>

    <%= link_to admin_shop_orders_path(preserved_filter_params.merge(status: 'awaiting_periodical_fulfillment')),
        class: "shop-orders__stat badge badge-awaiting_periodical_fulfillment" do %>
      Awaiting Fulfillment <span class="shop-orders__stat-count"><%= counts[:awaiting_fulfillment] %></span>
    <% end %>

    <% if policy(:admin).view_fraud_review_filters? %>
      <%= link_to admin_shop_orders_path(preserved_filter_params.merge(status: 'on_hold')),
          class: "shop-orders__stat badge badge-on_hold" do %>
        On Hold <span class="shop-orders__stat-count"><%= counts[:on_hold] %></span>
      <% end %>
    <% end %>

    <%= link_to admin_shop_orders_path(preserved_filter_params.merge(status: 'fulfilled')),
        class: "shop-orders__stat badge badge-fulfilled" do %>
      Fulfilled <span class="shop-orders__stat-count"><%= counts[:fulfilled] %></span>
    <% end %>

    <%= link_to admin_shop_orders_path(preserved_filter_params.merge(status: 'rejected')),
        class: "shop-orders__stat badge badge-rejected" do %>
      Rejected <span class="shop-orders__stat-count"><%= counts[:rejected] %></span>
    <% end %>

    <% if params[:status].present? %>
      <%= link_to admin_shop_orders_path(preserved_filter_params.except(:status)),
          class: "shop-orders__stat shop-orders__stat--clear" do %>
        ✕ Clear filter
      <% end %>
    <% end %>
  </div>

  <% if average_fulfillment_time %>
    <div class="shop-orders__avg-time">
      <strong>Average time from order to fulfilled:</strong>
      <span><%= distance_of_time_in_words(average_fulfillment_time) %></span>
    </div>
  <% end %>
</div>
