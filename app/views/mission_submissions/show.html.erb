<% content_for :title, "Submission ##{@submission.id}" %>

<%
  ship = @submission.ship_event
  project = ship&.post&.project
  builder = ship&.post&.user
  policy_obj = policy(@submission)
%>

<div class="app-layout">
  <div class="app-layout__main">
    <header class="submission-show__header">
      <p class="submission-show__breadcrumb">
        <%= link_to "Submissions", mission_submissions_path %>
      </p>
      <h1>
        <%= link_to @submission.mission.name, mission_path(@submission.mission.slug) %>
        <span class="status-pill status-pill--<%= @submission.status %>"><%= @submission.status.titleize %></span>
      </h1>
      <p class="submission-show__meta">
        Project: <%= link_to project.title, project_path(project) %> ·
        Builder: <%= builder&.display_name %> ·
        Payout path: <%= @submission.payout_path %>
      </p>
    </header>

    <% if @submission.rejection_message.present? %>
      <section class="submission-show__rejection">
        <h2>Rejection note</h2>
        <p><%= @submission.rejection_message %></p>
      </section>
    <% end %>

    <section class="submission-show__ship">
      <h2>Ship message</h2>
      <p><%= simple_format(ship.body.to_s) %></p>
      <% if ship.review_instructions.present? %>
        <h3>Review instructions</h3>
        <p><%= simple_format(ship.review_instructions.to_s) %></p>
      <% end %>
    </section>

    <% if policy_obj.review? %>
      <section class="submission-show__actions">
        <h2>Reviewer actions</h2>

        <% if @submission.may_approve? %>
          <%= button_to "Approve", approve_mission_submission_path(@submission),
                        method: :post, class: "btn btn--green" %>
        <% end %>

        <% if @submission.may_reject? %>
          <%= form_with url: reject_mission_submission_path(@submission), method: :post, local: true, class: "submission-show__reject-form" do %>
            <label>Rejection reason
              <%= text_area_tag :rejection_message, "", rows: 3, required: true %>
            </label>
            <%= submit_tag "Reject", class: "btn btn--red" %>
          <% end %>
        <% end %>

        <% if @submission.may_undo? %>
          <%= button_to "Undo decision", undo_mission_submission_path(@submission),
                        method: :post, class: "btn btn--brown" %>
        <% end %>
      </section>
    <% end %>

    <% if policy_obj.redeem? %>
      <section class="submission-show__redeem">
        <%= link_to "Pick a prize to redeem →", redeem_mission_submission_path(@submission),
                    class: "btn btn--green" %>
      </section>
    <% end %>

    <% if @versions.any? %>
      <section class="submission-show__timeline">
        <h2>Timeline</h2>
        <ol class="submission-show__timeline-list">
          <% @versions.each do |v| %>
            <li class="submission-show__timeline-item">
              <span class="submission-show__timeline-when"><%= v.created_at.strftime("%b %-d, %Y %H:%M") %></span>
              <span class="submission-show__timeline-event"><%= v.event %></span>
              <% if v.whodunnit.present? %>
                <span class="submission-show__timeline-who">by <%= @whodunnit_users[v.whodunnit]&.display_name || "system" %></span>
              <% end %>
            </li>
          <% end %>
        </ol>
      </section>
    <% end %>
  </div>
</div>
