<% content_for :title, "Verify your identity" %>

<div class="shop-tutorial-step">
  <div class="shop-tutorial-step__card">
    <p class="shop-tutorial-step__eyebrow">Identity check</p>
    <h1 class="shop-tutorial-step__title">Before you claim anything, we need to know who you are.</h1>

    <div class="shop-tutorial-step__body">
      <p>Stardance is run by Hack Club, a 501(c)(3) nonprofit. We verify every teen's identity through Hack Club Auth — it keeps the program safe, makes sure prizes reach the right person, and meets the rules nonprofits have to follow.</p>
      <p>It takes about a minute. You'll bounce out to Hack Club's portal and come right back here to finish your order.</p>
    </div>

    <%= render ActionButtonComponent.new(
          text: "Verify your identity",
          href: HCAService.verify_portal_url(return_to: request.original_url),
          variant: :primary,
          size: :large,
          class: "shop-tutorial-step__cta",
          data: { turbo: false }
        ) %>

    <footer class="shop-tutorial-step__footer">
      <p class="shop-tutorial-step__footer-line">501(c)(3) nonprofit · We don't sell data or run ads</p>
      <p class="shop-tutorial-step__footer-links">
        <%= link_to "Why we ask for your info →", guide_path("why_we_ask"), target: "_blank", rel: "noopener", class: "shop-tutorial-step__footer-link" %>
        <%= link_to "Privacy policy →", "https://hackclub.com/privacy", target: "_blank", rel: "noopener", class: "shop-tutorial-step__footer-link" %>
      </p>
    </footer>

    <p class="shop-tutorial-step__back">
      <%= link_to "← Back to the shop", shop_path, class: "shop-tutorial-step__back-link" %>
    </p>
  </div>
</div>
