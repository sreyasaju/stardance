<%= form_with(model: @vote, url: votes_path, id: "vote-score-form", data: { turbo: false }) do |form| %>
  <%= hidden_field_tag :suggestion_token, @suggestion_token %>
  <%= form.hidden_field :time_taken_to_vote, value: 0 %>
  <%= form.hidden_field :repo_url_clicked, value: false %>
  <%= form.hidden_field :demo_url_clicked, value: false %>

  <div class="vote-form">
    <% Vote.enabled_categories.each do |category| %>
      <%= render "category", form: form, category: category %>
    <% end %>

    <div class="vote-form__feedback" data-controller="word-count" data-word-count-min-words-value="10">
      <%= render InputComponent.new(
        form: form,
        attribute: :reason,
        label: "Feedback",
        placeholder: "Any thoughts for the maker? (at least 10 words)",
        color: :brown,
        subtitle: "Required. Write at least 10 words of feedback for the creator.",
        input_html: { data: { word_count_target: "input", action: "input->word-count#update" } }
      ) %>
      <%# <span class="word-count" data-word-count-target="output">0 / 10 words</span> %>
    </div>
  </div>
<% end %>

<%= render ActionButtonComponent.new(
  text: "Submit Vote",
  size: :large,
  variant: :primary,
  type: :submit,
  form: "vote-score-form",
  disable_with: "Submitting vote..."
) %>
