<%
  decision = local_assigns.fetch(:decision) { post.postable }
  project = local_assigns.fetch(:project) { post.project }
  approved = decision.approved?
  title = approved ? "Project certified" : "Returned for changes"
  message = if approved
    "This ship is approved and ready for voting."
  else
    "This needs changes before we can consider it shipped. Review the Shipwright feedback, make updates, then ship again."
  end
  decided_on = decision.decided_on || post.created_at
  reviewer_name = decision.reviewer&.display_name.presence
%>

<article id="<%= dom_id(post) %>"
         class="<%= class_names(
           "feed-post-card",
           "ship-decision-card",
           "ship-decision-card--#{decision.verdict}"
         ) %>">
  <div class="ship-decision-card__flag">
    <span class="ship-decision-card__label"
          tabindex="0"
          aria-label="Who are Shipwrights?"
          data-controller="tooltip"
          data-tooltip-title-value="Who are Shipwrights?"
          data-tooltip-message-value="Shipwrights are expert shippers who review submitted ships for quality, working demos, clear writeups, and program rules before projects move forward."
          data-tooltip-position-value="top">Shipwright Verdict</span>
  </div>

  <header class="ship-decision-card__main">
    <span class="ship-decision-card__mark" aria-hidden="true">
      <%= inline_svg_tag "icons/ship.svg", class: "ship-decision-card__mark-icon" %>
    </span>

    <div class="ship-decision-card__content">
      <h2 class="ship-decision-card__title"><%= title %></h2>
      <p class="ship-decision-card__meta">
        <span>on</span>
        <%= link_to project.title,
                    project_path(project),
                    class: "ship-decision-card__project",
                    data: { turbo_frame: "_top" } %>
        <time datetime="<%= decided_on.iso8601 %>" title="<%= l(decided_on, format: :long) %>">
          · <%= time_ago_in_words(decided_on) %>
        </time>
      </p>
      <% if reviewer_name %>
        <p class="ship-decision-card__reviewer">
          <span>Reviewed by</span>
          <%= link_to "@#{reviewer_name}",
                      profile_path(reviewer_name),
                      class: "ship-decision-card__reviewer-link",
                      data: { turbo_frame: "_top" } %>
        </p>
      <% end %>
      <p class="ship-decision-card__message"><%= message %></p>
    </div>
  </header>

  <% if decision.feedback.present? %>
    <section class="ship-decision-card__feedback" aria-label="Shipwright feedback">
      <p class="ship-decision-card__feedback-label">Shipwright feedback</p>
      <div class="ship-decision-card__feedback-body">
        <%= simple_format(decision.feedback, {}, sanitize: true) %>
      </div>
    </section>
  <% end %>
</article>
