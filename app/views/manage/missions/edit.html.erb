<% content_for :title, "Manage #{@mission.name}" %>

<div class="app-layout">
  <div class="app-layout__main">
    <header class="manage-mission__header">
      <p class="manage-mission__breadcrumb">
        <%= link_to "Mission", mission_path(@mission.slug) %>
      </p>
      <h1>Manage <%= @mission.name %></h1>
    </header>

    <section class="manage-mission__section">
      <h2 class="manage-mission__section-title">Mission details</h2>
      <%= form_with model: @mission, url: manage_mission_path(@mission.slug), method: :patch, local: true, multipart: true, class: "manage-mission__form" do |f| %>
        <label>Name <%= f.text_field :name, required: true %></label>
        <label>Description (markdown) <%= f.text_area :description, rows: 4 %></label>
        <label>Difficulty
          <%= f.select :difficulty, Mission::DIFFICULTIES.map { |d| [ d.titleize, d ] }, include_blank: "—" %>
        </label>
        <label><%= f.check_box :enabled %> Enabled</label>
        <label>Start at <%= f.datetime_field :start_at %></label>
        <label>End at <%= f.datetime_field :end_at %></label>
        <label>Featured at <%= f.datetime_field :featured_at %></label>
        <label>Achievement name <%= f.text_field :achievement_name %></label>
        <label>Achievement description <%= f.text_field :achievement_description %></label>
        <label>Icon <%= f.file_field :icon, accept: "image/*" %></label>
        <label>Banner <%= f.file_field :banner, accept: "image/*" %></label>
        <%= f.submit "Save details", class: "btn btn--green" %>
      <% end %>
    </section>

    <section class="manage-mission__section">
      <h2 class="manage-mission__section-title">Steps</h2>
      <ol class="manage-mission__steps">
        <% @steps.each_with_index do |step, idx| %>
          <li class="manage-mission__step">
            <strong><%= step.title %></strong>
            <div class="manage-mission__step-actions">
              <% if idx > 0 %>
                <%= button_to "↑", manage_mission_step_path(@mission.slug, step), method: :patch, params: { mission_step: { direction: "up" } }, class: "btn btn--brown btn--sm" %>
              <% end %>
              <% if idx < @steps.size - 1 %>
                <%= button_to "↓", manage_mission_step_path(@mission.slug, step), method: :patch, params: { mission_step: { direction: "down" } }, class: "btn btn--brown btn--sm" %>
              <% end %>
              <%= button_to "Delete", manage_mission_step_path(@mission.slug, step), method: :delete, data: { turbo_confirm: "Remove this step?" }, class: "btn btn--red btn--sm" %>
            </div>
            <details>
              <summary>Edit</summary>
              <%= form_with url: manage_mission_step_path(@mission.slug, step), method: :patch, local: true do %>
                <label>Title <%= text_field_tag "mission_step[title]", step.title, required: true, autocomplete: "off" %></label>
                <label>Body <%= text_area_tag "mission_step[body]", step.body, rows: 4 %></label>
                <%= submit_tag "Update step", class: "btn btn--green btn--sm" %>
              <% end %>
            </details>
          </li>
        <% end %>
      </ol>
      <%= form_with url: manage_mission_steps_path(@mission.slug), method: :post, local: true, class: "manage-mission__form" do %>
        <h3>Add step</h3>
        <label>Title <%= text_field_tag "mission_step[title]", nil, required: true, autocomplete: "off" %></label>
        <label>Body (markdown) <%= text_area_tag "mission_step[body]", nil, rows: 4 %></label>
        <%= submit_tag "Add step", class: "btn btn--green" %>
      <% end %>
    </section>

    <section class="manage-mission__section">
      <h2 class="manage-mission__section-title">Prizes</h2>
      <ul class="manage-mission__prizes">
        <% @prizes.each do |prize| %>
          <li class="manage-mission__prize">
            <%= prize.shop_item.name %>
            <%= button_to "Remove", manage_mission_prize_path(@mission.slug, prize), method: :delete, data: { turbo_confirm: "Remove this prize?" }, class: "btn btn--red btn--sm" %>
          </li>
        <% end %>
      </ul>
      <%= form_with url: manage_mission_prizes_path(@mission.slug), method: :post, local: true, class: "manage-mission__form" do %>
        <h3>Add prize</h3>
        <label>Shop item
          <%= select_tag "mission_prize[shop_item_id]",
              options_from_collection_for_select(ShopItem.where(mission_prize_only: true).order(:name), :id, :name),
              prompt: "Select a mission-prize-only shop item" %>
        </label>
        <%= submit_tag "Add prize", class: "btn btn--green" %>
      <% end %>
    </section>

    <section class="manage-mission__section">
      <h2 class="manage-mission__section-title">Memberships</h2>
      <ul class="manage-mission__memberships">
        <% @memberships.each do |m| %>
          <li class="manage-mission__membership">
            <%= m.user.display_name %> — <em><%= m.role.titleize %></em>
            <%= button_to "Remove", manage_mission_membership_path(@mission.slug, m), method: :delete, data: { turbo_confirm: "Remove this member?" }, class: "btn btn--red btn--sm" %>
          </li>
        <% end %>
      </ul>
      <%= form_with url: manage_mission_memberships_path(@mission.slug), method: :post, local: true, class: "manage-mission__form" do %>
        <h3>Add member</h3>
        <label>User ID or Slack ID <%= text_field_tag "mission_membership[user_id]", nil, required: true, autocomplete: "off" %></label>
        <label>Role
          <%= select_tag "mission_membership[role]", options_for_select(Mission::Membership.roles.keys.map { |r| [ r.titleize, r ] }) %>
        </label>
        <%= submit_tag "Add member", class: "btn btn--green" %>
      <% end %>
    </section>

    <section class="manage-mission__section">
      <h2 class="manage-mission__section-title">Shop unlocks</h2>
      <p class="manage-mission__hint">Items that completing this mission will unlock for the user.</p>
      <ul class="manage-mission__unlocks">
        <% @unlocks.each do |u| %>
          <li class="manage-mission__unlock">
            <%= u.shop_item.name %>
            <%= button_to "Remove", manage_mission_shop_unlock_path(@mission.slug, u), method: :delete, data: { turbo_confirm: "Remove this unlock?" }, class: "btn btn--red btn--sm" %>
          </li>
        <% end %>
      </ul>
      <%= form_with url: manage_mission_shop_unlocks_path(@mission.slug), method: :post, local: true, class: "manage-mission__form" do %>
        <h3>Add shop unlock</h3>
        <label>Shop item
          <%= select_tag "mission_shop_unlock[shop_item_id]",
              options_from_collection_for_select(ShopItem.order(:name), :id, :name),
              prompt: "Select a shop item" %>
        </label>
        <%= submit_tag "Add unlock", class: "btn btn--green" %>
      <% end %>
    </section>
  </div>
</div>
