<aside class="discover-rail" aria-label="Discover">
  <div class="discover-rail__search">
    <input type="text" class="discover-rail__search-input" placeholder="Search…" aria-label="Search" autocomplete="off" disabled>
    <%= helpers.inline_svg_tag "icons/search.svg", class: "discover-rail__search-icon" %>
  </div>

  <section class="discover-rail__section" aria-label="Popular projects this week">
    <h2 class="discover-rail__heading">Popular projects this week</h2>
    <div class="discover-rail__placeholder discover-rail__placeholder--tall"></div>
  </section>

  <section class="discover-rail__section" aria-label="Missions for you">
    <h2 class="discover-rail__heading">Missions for you</h2>
    <div class="discover-rail__placeholder"></div>
    <div class="discover-rail__placeholder"></div>
  </section>

  <section class="discover-rail__section" aria-label="Stardance updates">
    <h2 class="discover-rail__heading">Stardance updates</h2>
    <div class="discover-rail__placeholder"></div>
    <div class="discover-rail__placeholder"></div>
  </section>
</aside>
