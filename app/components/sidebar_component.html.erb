<aside class="sidebar"
       id="primary-nav"
       data-controller="sidebar-active nav-history"
       data-turbo-permanent
       aria-label="Main">
  <%= link_to root_path, class: "sidebar__logo", "aria-label": "Stardance home" do %>
    <%= image_tag "landing/header/stardance-logo.png", alt: "Hack Club Stardance Challenge", class: "sidebar__logo-img" %>
  <% end %>

  <nav class="sidebar__nav" aria-label="Primary navigation">
    <ul class="sidebar__nav-list">
      <% nav_items.each do |item| %>
        <% link_classes = link_classes_for(item) %>

        <li class="sidebar__nav-item" data-onboarding-target="<%= item[:slug] %>">
          <% icon_block = capture do %>
            <span class="sidebar__nav-icon-wrapper" aria-hidden="true">
              <% if item[:icon] == :avatar %>
                <% if user.slack_id.present? %>
                  <%= image_tag user.avatar, alt: "", class: "sidebar__nav-avatar" %>
                <% else %>
                  <span class="sidebar__nav-avatar sidebar__nav-avatar--placeholder">
                    <%= user.display_name.first.upcase %>
                  </span>
                <% end %>
              <% else %>
                <%= inline_svg_tag "icons/#{item[:icon]}.svg", class: "sidebar__nav-icon" %>
              <% end %>
            </span>
          <% end %>

          <% if item[:locked] %>
            <button type="button"
                    class="<%= link_classes %> sidebar__nav-link--locked"
                    data-controller="locked-tab"
                    data-locked-tab-message-value="<%= item[:locked_message] %>"
                    aria-disabled="true"
                    aria-haspopup="dialog"
                    aria-label="<%= item[:label] %> (locked) — click for details">
              <%= icon_block %>
              <span class="sidebar__nav-label"><%= item[:label] %></span>
              <span class="sidebar__nav-lock" aria-hidden="true">
                <%= inline_svg_tag "icons/lock.svg", class: "sidebar__nav-lock-icon" %>
              </span>
            </button>
          <% elsif item[:path] == "#" %>
            <span class="<%= link_classes %> sidebar__nav-link--inert" aria-disabled="true">
              <%= icon_block %>
              <span class="sidebar__nav-label"><%= item[:label] %></span>
            </span>
          <% else %>
            <%= link_to item[:path], class: link_classes, aria: (active?(item) ? { current: "page" } : {}), data: { active_prefix: item[:active_prefix] }.compact do %>
              <%= icon_block %>
              <span class="sidebar__nav-label"><%= item[:label] %></span>
            <% end %>
          <% end %>
        </li>
      <% end %>
    </ul>
  </nav>

  <div class="sidebar__user" aria-live="polite">
    <div class="sidebar__user-card">
      <div class="sidebar__user-meta">
        <span class="sidebar__user-meta-label">logged in as</span>
        <%= link_to user_path(user), class: "sidebar__user-meta-handle" do %>
          @<%= user.display_name %>
        <% end %>
      </div>

      <div class="sidebar__user-actions">
        <button type="button" class="sidebar__user-settings" onclick="document.getElementById('settings-modal').showModal()" aria-label="Settings">
          <%= inline_svg_tag "icons/gear.svg", class: "sidebar__user-settings-icon" %>
        </button>

        <button type="button" class="sidebar__user-logout" onclick="document.getElementById('logout-form').submit()" aria-label="Logout">
          <%= inline_svg_tag "icons/logout.svg", class: "sidebar__user-logout-icon" %>
        </button>

        <%= form_with url: logout_path, method: :delete, id: "logout-form", style: "display: none;" do %>
        <% end %>
      </div>
    </div>
  </div>

  <%= render layout: "shared/modal", locals: { id: "settings-modal", title: "Settings" } do %>
    <% preference = user.preference %>
    <%= form_with url: my_settings_path, method: :patch, local: true, class: "settings-form", id: "settings-form", data: { turbo: false } do |f| %>
      <div class="settings-form__field">
        <label class="settings-form__label" for="hcb_email">HCB Email</label>
        <%= text_field_tag :hcb_email, user.hcb_email, id: "hcb_email", class: "settings-form__input", placeholder: user.email, autocomplete: "email" %>
        <small class="settings-form__hint">Email used for receiving HCB grants. Leave blank to use your default
          email.</small>
      </div>

      <div class="settings-form__field">
        <label class="settings-form__checkbox">
          <%= check_box_tag :send_votes_to_slack, "1", preference.send_votes_to_slack, id: "send_votes_to_slack" %>
          <span>Send votes to Slack</span>
        </label>
        <small class="settings-form__hint">Share your votes in #flavortown-share-votes</small>
      </div>

      <div class="settings-form__field">
        <label class="settings-form__checkbox">
          <%= check_box_tag :leaderboard_optin, "1", preference.leaderboard_optin, id: "leaderboard_optin" %>
          <span>Opt in to the leaderboard</span>
        </label>
        <small class="settings-form__hint">Check this if you want to be shown on the leaderboard</small>
      </div>

      <div class="settings-form__field">
        <label class="settings-form__checkbox">
          <%= check_box_tag :stardust_balance_notifications, "1", preference.stardust_balance_notifications, id: "stardust_balance_notifications" %>
          <span>Balance change notifications</span>
        </label>
        <small class="settings-form__hint">Receive a Slack DM when your Stardust balance changes</small>
      </div>

      <div class="settings-form__field">
        <label class="settings-form__checkbox">
          <%= check_box_tag :send_notifications_for_followed_projects, "1", preference.send_notifications_for_followed_projects, id: "send_notifications_for_followed_projects" %>
          <span>Followed project notifications</span>
        </label>
        <small class="settings-form__hint">Receive a Slack DM when a project you're following has a new devlog</small>
      </div>

      <div class="settings-form__field">
        <label class="settings-form__checkbox">
          <%= check_box_tag :send_notifications_for_new_followers, "1", preference.send_notifications_for_new_followers, id: "send_notifications_for_new_followers" %>
          <span>New follower notifications</span>
        </label>
        <small class="settings-form__hint">Receive a Slack DM when someone starts following a project you're making</small>
      </div>

      <div class="settings-form__field">
        <label class="settings-form__checkbox">
          <%= check_box_tag :send_notifications_for_new_comments, "1", preference.send_notifications_for_new_comments, id: "send_notifications_for_new_comments" %>
          <span>New comment notifications</span>
        </label>
        <small class="settings-form__hint">Receive a Slack DM when someone comments on a project you made</small>
      </div>

      <div class="settings-form__field">
        <label class="settings-form__checkbox">
          <%= check_box_tag :search_engine_indexing_off, "1", preference.search_engine_indexing_off, id: "search_engine_indexing_off" %>
          <span>Opt out of search engine indexing</span>
        </label>
        <small class="settings-form__hint">Your profile will not be indexed by search engines</small>
      </div>

      <div class="modal__actions">
        <%= f.submit "Save", class: "modal__actions-close" %>
        <button type="button" class="modal__actions-close" onclick="document.getElementById('settings-form').reset(); document.getElementById('settings-modal').close()">Cancel</button>
      </div>
    <% end %>

  <% end %>
</aside>
